# === Docker 相關 ===
# 專案代號（compose 會自動補 -frontend 後綴，請勿自行加）
PROJECT_NAME=nuxt4-template
IMAGE_TAG=latest
HOST_PORT=3000

# === Nuxt Runtime Config ===
NUXT_APP_BASE_URL=/
# 統一 API domain（覆蓋 runtimeConfig.public.apiBase；預設 /api）
NUXT_PUBLIC_API_BASE=http://localhost:3000/api
NUXT_PRIVATE_GOOGLE_SHEET_KEY=
