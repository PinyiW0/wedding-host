# === Docker 相關 ===
# 專案代號（compose 會自動補 -frontend 後綴，請勿自行加）
PROJECT_NAME=nuxt4-template
IMAGE_TAG=latest
HOST_PORT=3000

# === Nuxt Runtime Config ===
NUXT_APP_BASE_URL=/
# 統一 API domain（覆蓋 runtimeConfig.public.apiBase）
# mock 階段：前後端同源（mock API 由本 nuxt server 提供），留空走相對路徑即可
#（wrapper 路徑已內含 /api/v1 前綴，不可重複）。M0 接「外部」後端時才設為該 API host。
NUXT_PUBLIC_API_BASE=
NUXT_PRIVATE_GOOGLE_SHEET_KEY=
  